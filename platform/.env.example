# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Admin
ADMIN_PIN=your-6-digit-pin
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
ADMIN_TOKEN_SECRET=generate-with-openssl-rand-hex-32

# Security secrets
CRON_SECRET=generate-with-openssl-rand-hex-32
PORTAL_SECRET=generate-with-openssl-rand-hex-32
TEAM_PORTAL_SECRET=generate-with-openssl-rand-hex-32

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx

# SMS (Telnyx)
# TELNYX_API_KEY=KEY_xxx
# TELNYX_PHONE=+1xxxxxxxxxx

# Payments (Stripe)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google OAuth (for reviews/business profile)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# App URL
NEXT_PUBLIC_APP_URL=https://app.fullloopcrm.com
